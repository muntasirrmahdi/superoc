{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SuperOC State",
  "type": "object",
  "properties": {
    "user": {
      "type": "object",
      "properties": {
        "content": { "type": "string" }
      },
      "required": ["content"]
    },
    "identity": {
      "type": "object",
      "properties": {
        "content": { "type": "string" }
      },
      "required": ["content"]
    },
    "memory": {
      "type": "object",
      "properties": {
        "content": { "type": "string" }
      },
      "required": ["content"]
    },
    "last_compiled": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["user", "identity", "memory", "last_compiled"]
}
