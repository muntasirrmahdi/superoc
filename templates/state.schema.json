{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SuperOC State",
  "type": "object",
  "properties": {
    "user": { "type": "object", "properties": { "content": { "type": "string" } }, "required": ["content"] },
    "identity": { "type": "object", "properties": { "content": { "type": "string" } }, "required": ["content"] },
    "memory": { "type": "object", "properties": { "content": { "type": "string" } }, "required": ["content"] },
    "learning_model": { "type": "object", "properties": { "content": { "type": "string" } }, "required": ["content"] },
    "understanding_model": { "type": "object", "properties": { "content": { "type": "string" } }, "required": ["content"] },
    "wikilinks_graph": { "type": "object" },
    "daily": { "type": "object", "properties": { "logs": { "type": "object" } } },
    "days_loaded": { "type": "integer" },
    "ready": { "type": "boolean" },
    "_meta": { "type": "object", "properties": { "last_compiled": { "type": "string" } } }
  },
  "required": ["user", "identity", "memory", "learning_model", "understanding_model", "ready", "_meta"]
}