#!/usr/bin/env bash
# bin/superoc - Main wrapper for SuperOC Memory Stack
# Intercepts agent execution and ensures memory enforcement

set -euo pipefail

SUPEROC_DIR="${SUPEROC_DIR:-$HOME/.superoc}"
STATE_FILE="$SUPEROC_DIR/state.json"
SHELL_ENV="$SUPEROC_DIR/shell.env"
MONITORING_DIR="$SUPEROC_DIR/monitoring"
COMPLIANCE_LOG="$MONITORING_DIR/compliance/startup-$(date +%Y%m%d_%H%M%S).log"

mkdir -p "$MONITORING_DIR/logs" "$MONITORING_DIR/alerts" "$MONITORING_DIR/compliance" "$SUPEROC_DIR/logs"

# === Load memory state ===
if [ -f "$SHELL_ENV" ]; then
    source "$SHELL_ENV"
fi

if [ "${SUPEROC_MEMORY_READY:-false}" != "true" ]; then
    if [ -x "$SUPEROC_DIR/lib/load_memory.sh" ]; then
        source "$SUPEROC_DIR/lib/load_memory.sh" 2>/dev/null || true
    fi
fi

# === Display memory status ===
if [ "${SUPEROC_MEMORY_READY:-false}" = "true" ]; then
    echo "[ SuperOC Memory: LOADED ]"
    if [ -n "$SUPEROC_USER_NAME" ]; then
        echo "User: $SUPEROC_USER_NAME"
    fi
    if [ -f "$SUPEROC_DIR/lib/sync_knowledge.sh" ] && [ -x "$SUPEROC_DIR/lib/sync_knowledge.sh" ]; then
        "$SUPEROC_DIR/lib/sync_knowledge.sh" > /dev/null 2>&1 &
        echo "[AI] SuperOC Intelligence: SYNCHRONIZING (Background) [OK]"
    fi
fi

echo "[+] Starting rule compliance verification..."

# === Verification ===
STATE_JSON_VALID="false"
AGENTS_FILE_EXISTS="false"
AGENTS_CONTENT_VALID="false"
VERIFICATION_STATUS="unknown"

if [ -f "$STATE_FILE" ]; then
    if jq empty "$STATE_FILE" 2>/dev/null; then
        STATE_JSON_VALID="true"
        echo "[OK] state.json: exists and valid JSON"
    else
        echo "[!] state.json: exists but invalid JSON"
    fi
else
    echo "[X] state.json: file not found"
fi

# Determine compliance file based on agent
AGENT_CMD_NAME="${1:-opencode}"
case "$AGENT_CMD_NAME" in
    opencode)
        OPENCODE_CONFIG_DIR="${OPENCODE_CONFIG_DIR:-$HOME/.config/opencode}"
        AGENTS_FILE="$OPENCODE_CONFIG_DIR/AGENTS.md"
        ;;
    claude*)
        AGENT_CONFIG_DIR="$HOME/.config/claudecode"
        AGENTS_FILE="$AGENT_CONFIG_DIR/config.json" # Adjust based on agent
        ;;
    *)
        AGENTS_FILE=""
        ;;
esac

if [ -f "$AGENTS_FILE" ]; then
    AGENTS_FILE_EXISTS="true"
    echo "[OK] Compliance file: $(basename "$AGENTS_FILE") exists"
    if grep -qiE "MANDATORY FIRST ACTION|state.json" "$AGENTS_FILE"; then
        AGENTS_CONTENT_VALID="true"
        echo "[OK] Compliance file: contains memory loading rule"
    else
        echo "[!] Compliance file: missing critical memory loading rule"
    fi
else
    # For unknown agents, we don't fail verification if the file is missing
    if [[ "$AGENT_CMD_NAME" != "opencode" ]]; then
        AGENTS_FILE_EXISTS="true"
        AGENTS_CONTENT_VALID="true"
        echo "[OK] Compliance check: skipped for non-OpenCode agent (manual verification recommended)"
    else
        echo "[X] AGENTS.md: file not found"
    fi
fi

if [ "$STATE_JSON_VALID" = "true" ] && [ "$AGENTS_FILE_EXISTS" = "true" ] && [ "$AGENTS_CONTENT_VALID" = "true" ]; then
    VERIFICATION_STATUS="verified"
elif [ "$STATE_JSON_VALID" = "false" ] || [ "$AGENTS_FILE_EXISTS" = "false" ] || [ "$AGENTS_CONTENT_VALID" = "false" ]; then
    VERIFICATION_STATUS="failed"
else
    VERIFICATION_STATUS="partial"
fi

# === Save compliance log ===
{
    echo "=== SuperOC Rule Compliance Verification ==="
    echo "Timestamp: $(date -Iseconds)"
    echo "Session PID: $$"
    echo "User: $(whoami)"
    echo "---"
    echo "Verification Status: $VERIFICATION_STATUS"
    echo "state.json valid: $STATE_JSON_VALID"
    echo "AGENTS.md exists: $AGENTS_FILE_EXISTS"
    echo "AGENTS.md content valid: $AGENTS_CONTENT_VALID"
    echo "SUPEROC_MEMORY_READY: ${SUPEROC_MEMORY_READY:-unset}"
} > "$COMPLIANCE_LOG"

echo "[STATS] Verification complete: $VERIFICATION_STATUS"
echo "[LOG] Log saved to: $COMPLIANCE_LOG"

# === FIX 1.2: Exit if adapter missing for known agents ===
AGENT_CMD="${1:-}"

if [[ -z "$AGENT_CMD" || "$AGENT_CMD" == "--help" || "$AGENT_CMD" == "-h" ]]; then
    echo "SuperOC Memory Stack Wrapper"
    echo "Usage: superoc <agent_command> [args...]"
    echo "Example: superoc opencode"
    echo ""
    echo "Available commands:"
    echo "  compile             Manually compile state.json"
    echo "  health              Run health checks"
    echo "  <agent>             Run an agent with memory enforcement"
    exit 0
fi

shift  # Remove agent command from args

# Known agents that require specific adapters
KNOWN_AGENTS="opencode claude claudecode cursor generic"

# Determine the correct adapter
ADAPTER_FILE="$SUPEROC_DIR/lib/adapters/${AGENT_CMD}.sh"

# === FIX 1.2: Exit if known agent but no adapter ===
if [[ -n "$AGENT_CMD" && -f "$SUPEROC_DIR/lib/adapters/${AGENT_CMD}.sh" ]]; then
    ADAPTER_FILE="$SUPEROC_DIR/lib/adapters/${AGENT_CMD}.sh"
elif [[ ! -f "$ADAPTER_FILE" ]]; then
    # Unknown agent - try generic or fail
    if [[ -f "$SUPEROC_DIR/lib/adapters/generic.sh" ]]; then
        ADAPTER_FILE="$SUPEROC_DIR/lib/adapters/generic.sh"
    else
        echo "WARNING: No adapter found for '$AGENT_CMD'. Proceeding without memory injection."
        echo "       Known agents: $KNOWN_AGENTS"
        ADAPTER_FILE=""
    fi
fi

# === FIX 4.1: Recovery from corrupted state.json ===
# If state.json is corrupted or missing, try to rebuild
if [[ -f "$STATE_FILE" ]]; then
    if ! jq -e '.' "$STATE_FILE" >/dev/null 2>&1; then
        echo "WARNING: Corrupted state.json detected. Attempting recovery..."
        rm -f "$STATE_FILE"
    fi
fi

# 1. State Compilation
if [[ -x "$SUPEROC_DIR/lib/compile_state.sh" ]]; then
    "$SUPEROC_DIR/lib/compile_state.sh" || {
        echo "ERROR: State compilation failed."
        exit 1
    }
else
    echo "ERROR: lib/compile_state.sh not found or not executable. Installation broken."
    exit 1
fi

    # === FIX 1.5: Inject memory directive via adapter and verify ===
    if [ -n "$ADAPTER_FILE" ]; then
        # Run adapter to inject memory directive (default action)
        "$ADAPTER_FILE" 2>/dev/null || true
        # Verify injection
        if ! "$ADAPTER_FILE" "verify" 2>/dev/null; then
            echo "WARNING: Could not verify memory injection."
        fi
        # Create flag file to indicate state was prepared for loading
        touch "$SUPEROC_DIR/state_loaded.flag" 2>/dev/null || true
    fi

# === FIX 3.4: trap INT in child processes ===
# 3. Setup Post-Flight Trap (multiple signals)
if [[ -x "$SUPEROC_DIR/lib/post_session_audit.sh" ]]; then
    POST_AUDIT="$SUPEROC_DIR/lib/post_session_audit.sh"
    # Catch multiple termination signals
    trap '$POST_AUDIT' EXIT INT TERM HUP QUIT
    
    # === FIX 3.4: Also trap child processes ===
    # Use subshell to ensure trap propagates
    (
        trap 'eval "$POST_AUDIT"' EXIT INT TERM HUP QUIT
    ) &
fi

# === FIX 4.3: Check for cron-based checkpoint (optional) ===
if [[ -x "$SUPEROC_DIR/lib/monitor_health.sh" ]]; then
    # Optional health check - don't fail if this fails
    "$SUPEROC_DIR/lib/monitor_health.sh" 2>/dev/null || true
fi

# === FIX 7.1: Set bypass guard environment variable ===
export SUPEROC_ACTIVE=1
echo "[Guard] Bypass guard active (SUPEROC_ACTIVE=1)"

# === FIX 8.1: Start periodic session checkpoint ===
if [[ -x "$SUPEROC_DIR/lib/session_checkpoint.sh" ]]; then
    CHECKPOINT_INTERVAL="${CHECKPOINT_INTERVAL:-300}" "$SUPEROC_DIR/lib/session_checkpoint.sh" &
    CHECKPOINT_PID=$!
    echo "[Checkpoint] Periodic checkpoint started (PID: $CHECKPOINT_PID, interval: ${CHECKPOINT_INTERVAL:-300}s)"
fi

# 4. Pass control to the underlying agent
if command -v "$AGENT_CMD" >/dev/null 2>&1; then
    SESSION_LOG="$SUPEROC_DIR/logs/latest_session.log"
    SCRIPT_BIN=$(which script 2>/dev/null || echo "")
    
    # === FIX 6.1: Start background supervisor ===
    if [[ -x "$SUPEROC_DIR/lib/background_supervisor.sh" ]]; then
        # We pass the wrapper PID, the supervisor will resolve the agent PID
        "$SUPEROC_DIR/lib/background_supervisor.sh" "$$" "$AGENT_CMD" &
        SUPERVISOR_PID=$!
        echo "[Supervisor] Background supervisor started (PID: $SUPERVISOR_PID)"
    fi

    if [[ -n "$SCRIPT_BIN" ]]; then
        # === TTY STABILIZATION FIX ===
        # Run script in FOREGROUND to prevent TTY contention and mouse tracking slop
        TMP_SCRIPT=$(mktemp /tmp/superoc_agent.XXXXXX.sh)
        cat > "$TMP_SCRIPT" << 'INNER_EOF'
#!/bin/bash
exec "$@"
INNER_EOF
        chmod +x "$TMP_SCRIPT"
        
        # Build command string for script -c carefully
        CMD_EXEC="\"$TMP_SCRIPT\" \"$AGENT_CMD\""
        for arg in "$@"; do
            CMD_EXEC="$CMD_EXEC \"$arg\""
        done
        
        "$SCRIPT_BIN" -q -c "$CMD_EXEC" "$SESSION_LOG"
        EXIT_CODE=$?
        rm -f "$TMP_SCRIPT"
    else
        # Fallback: run without transcript capture
        "$AGENT_CMD" "$@"
        EXIT_CODE=$?
        echo "[Agent] Started $AGENT_CMD [WARNING: transcript capture not available]"
    fi
    
    # Stop supervisor
    if [[ -n "${SUPERVISOR_PID:-}" ]] && kill -0 "$SUPERVISOR_PID" 2>/dev/null; then
        kill "$SUPERVISOR_PID" 2>/dev/null || true
    fi
    
    exit $EXIT_CODE
else
    echo "ERROR: Agent '$AGENT_CMD' not found."
    exit 1
fi