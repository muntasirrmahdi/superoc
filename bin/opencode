#!/usr/bin/env bash
# bin/opencode - Convenience wrapper for SuperOC
# This script ensures that 'opencode' is always run through 'superoc'
# to maintain intercept/inject/run/extract lifecycle.

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SUPEROC_BIN="$BIN_DIR/superoc"

if [[ -x "$SUPEROC_BIN" ]]; then
    exec "$SUPEROC_BIN" opencode "$@"
else
    # Fallback to finding superoc in PATH
    if command -v superoc >/dev/null 2>&1; then
        exec superoc opencode "$@"
    else
        echo "ERROR: superoc binary not found."
        exit 1
    fi
fi
